{
  "name": "banco-moc-popup-video",
  "version": "1.0.0",
  "description": "Aplicação de agendamento com reprodução de vídeos em popup",
  "author": "Fernando Zucula",
  "license": "MIT",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --inspect=5858",
    "debug": "electron . --remote-debugging-port=9222",
    "dist": "npm run dist:linux",
    "dist:linux": "electron-builder --linux"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "electron": "^27.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.bancomoc.popupvideo",
    "productName": "Banco Moc Popup Video",
    "asar": true,
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "buildDependenciesFromSource": false,
    "forceCodeSigning": false,
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "linux": {
      "icon": "assets/icons/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    }
  }
}
