{
  "name": "popup-video-player-with-scheduler",
  "version": "1.0.0",
  "description": "Aplicação de agendamento com reprodução de vídeos em popup",
  "author": "Fernando Zucula",
  "license": "MIT",
  "main": "src/main.js",

  "scripts": {
    "start": "electron .",
    "dev": "electron . --inspect=5858",
    "debug": "electron . --remote-debugging-port=9222",
    "dist": "electron-builder --win",
    "dist:all": "electron-builder -w -m -l"
  },

  "keywords": [
    "electron",
    "video",
    "scheduler",
    "popup",
    "player"
  ],

  "dependencies": {
    "axios": "^1.6.0"
  },

  "devDependencies": {
    "electron": "^27.0.0",
    "electron-builder": "^24.13.3"
  },

  "build": {
    "appId": "com.popup.videoplayer.scheduler",
    "productName": "Popup Video Scheduler",
    "copyright": "© 2025 Fernando Z.",
    "asar": true,

    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },

    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],

    "win": {
      "target": ["nsis", "msi"],
      "icon": "assets/icon.ico",
      "sign": false
    },

    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Popup Video Scheduler"
    },

    "msi": {
      "oneClick": false,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
